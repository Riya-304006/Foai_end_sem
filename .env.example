# ============================================================
#  SpaceOS — Environment Variables
# ============================================================
#
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it is already in .gitignore.
# ============================================================

# -----------------------------------------------------------
# NEWS API  (https://newsapi.org)
# 1. Go to https://newsapi.org/register
# 2. Sign up for a free account
# 3. Copy your API key from the dashboard
# 4. Paste it below (replace "your_news_api_key")
# -----------------------------------------------------------
VITE_NEWS_API_KEY=pub_4ddde2416e8545308b65d3dfe91e9a85

# -----------------------------------------------------------
# HUGGING FACE TOKEN  (https://huggingface.co)
# 1. Sign up / log in at https://huggingface.co
# 2. Go to Settings → Access Tokens
#    (https://huggingface.co/settings/tokens)
# 3. Click "New token" → choose role "Read" → Create
# 4. Copy the token (starts with hf_...)
# 5. Paste it below (replace "your_huggingface_token")
#
# WHERE TO PASTE IT IN CODE:
#   src/pages/Chatbot.jsx → passed as Authorization header
#   Authorization: Bearer ${import.meta.env.VITE_AI_TOKEN}
# -----------------------------------------------------------
VITE_AI_TOKEN=your_huggingface_token_here
